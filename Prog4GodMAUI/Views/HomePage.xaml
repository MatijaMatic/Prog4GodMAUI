<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Prog4GodMAUI.Converters"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Converters;assembly=CommunityToolkit.Maui"
             xmlns:behaviors="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             x:Class="Prog4GodMAUI.Views.HomePage"
             Title="HomePage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:CategoryToColorConverter x:Key="CategoryToColorConverter" />
            <converters:FirstLetterUppercaseConverter x:Key="FirstLetterUppercaseConverter" />
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <behaviors:EventToCommandBehavior Command="{Binding InitCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>

    <Shell.TitleView>
        <Label
        FontAttributes="Bold"
        FontSize="Large"
        HorizontalOptions="Center"
        VerticalOptions="Center">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Green" TextColor="ForestGreen" />
                    <Span Text="Store" TextColor="White" />
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </Shell.TitleView>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Fixed  -->
        <StackLayout Grid.Row="0">
            <!--  Search Bar Background  -->
            <Frame
            Margin="0"
            Padding="0,0,0,30"
            BackgroundColor="{StaticResource Primary}"
            BorderColor="{StaticResource Primary}"
            CornerRadius="0"
            HorizontalOptions="Fill"
            VerticalOptions="Center" />

            <!--  Search Bar Frame  -->
            <Frame
            Margin="30,-20,30,0"
            Padding="10"
            BackgroundColor="White"
            BorderColor="Transparent"
            CornerRadius="20">
                <StackLayout HorizontalOptions="Fill" Orientation="Horizontal">
                    <Image
                    Aspect="AspectFit"
                    HeightRequest="20"
                    Source="search.svg"
                    VerticalOptions="Center"
                    WidthRequest="20" />
                    <Label
                    Padding="20,0"
                    HorizontalOptions="Start"
                    Text="Search products"
                    TextColor="Gray"
                    VerticalOptions="Center" />
                </StackLayout>
            </Frame>
        </StackLayout>

        <!--  ScrollView  -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
            <StackLayout Padding="12,10">
                <Label
                Margin="0,15,0,10"
                FontAttributes="Bold"
                FontFamily="AstoreEczarSemiBold"
                FontSize="20"
                HorizontalOptions="Start"
                Text="Categories"
                VerticalOptions="Start" />

                <!--  Horizontal ScrollView for categories  -->
                <ScrollView HorizontalScrollBarVisibility="Default" Orientation="Horizontal">
                    <StackLayout Padding="0,10" Orientation="Horizontal">
                        <CollectionView ItemsLayout="HorizontalList" ItemsSource="{Binding Categories}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame
                                    Margin="10,0"
                                    Padding="0"
                                    BackgroundColor="White"
                                    BorderColor="Transparent"
                                    CornerRadius="8"
                                    HasShadow="False"
                                    HeightRequest="90"
                                    WidthRequest="160">
                                        <StackLayout>
                                            <!--  Image  -->
                                            <Image
                                            Aspect="AspectFill"
                                            HeightRequest="140"
                                            HorizontalOptions="Fill"
                                            Source="{Binding ImageName}"
                                            VerticalOptions="Fill"
                                            ZIndex="1" />

                                            <!--  Desaturation Overlay  -->
                                            <BoxView
                                            Margin="0,-140,0,0"
                                            HeightRequest="140"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Fill"
                                            ZIndex="2"
                                            Color="#339e9e9e" />

                                            <!--  Label  -->
                                            <Label
                                            Margin="0,-80,0,0"
                                            FontAttributes="Bold"
                                            FontFamily="AstoreEczarSemiBold"
                                            FontSize="15"
                                            HeightRequest="20"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="CharacterWrap"
                                            Text="{Binding Name, Converter={StaticResource FirstLetterUppercaseConverter}}"
                                            TextColor="White"
                                            VerticalTextAlignment="Center"
                                            ZIndex="4" />
                                        </StackLayout>

                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.CategoryTappedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                </ScrollView>

                <Label
                Margin="0,15,0,10"
                FontAttributes="Bold"
                FontFamily="AstoreEczarSemiBold"
                FontSize="20"
                HorizontalOptions="Start"
                Text="Featured products"
                VerticalOptions="Start" />

                <!--  Vertical ScrollView for products  -->
                <CollectionView ItemsSource="{Binding Products}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <StackLayout Margin="10" WidthRequest="160">
                                <!--  Image Frame  -->
                                <Frame
                                Padding="1"
                                BorderColor="Transparent"
                                CornerRadius="8"
                                HasShadow="False">
                                    <Grid>
                                        <!--  product image  -->
                                        <Image
                                        Margin="20"
                                        Aspect="AspectFit"
                                        HeightRequest="130"
                                        Source="{Binding Image}">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.ProductTappedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </Grid>
                                </Frame>

                                <!--  rating, title, price  -->
                                <FlexLayout
                                Margin="5,0"
                                AlignItems="Start"
                                Direction="Column"
                                JustifyContent="Start">

                                    <!--  rating  -->
                                    <FlexLayout
                                    AlignItems="Start"
                                    AlignSelf="Center"
                                    Direction="Row"
                                    HeightRequest="30"
                                    JustifyContent="Start"
                                    Wrap="NoWrap">
                                        <Image
                                        Aspect="AspectFit"
                                        HeightRequest="16"
                                        HorizontalOptions="Start"
                                        Source="star_filled_yellow.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="16" />
                                        <Label
                                        FontAttributes="Bold"
                                        FontFamily="AstoreEczarSemiBold"
                                        FontSize="Small"
                                        HorizontalOptions="Start"
                                        Text="{Binding Rating.Rate}"
                                        TextColor="Black"
                                        VerticalTextAlignment="Center" />
                                    </FlexLayout>

                                    <!--  title  -->
                                    <Label
                                    Margin="0,3"
                                    FontFamily="AstoreEczarSemiBold"
                                    FontSize="Small"
                                    HeightRequest="38"
                                    LineBreakMode="WordWrap"
                                    MaxLines="2"
                                    Text="{Binding Title}"
                                    TextColor="#000" />

                                    <!--  price  -->
                                    <Label
                                    FontAttributes="Bold"
                                    FontFamily="AstoreEczarSemiBold"
                                    FontSize="Medium"
                                    HeightRequest="30"
                                    HorizontalOptions="Start"
                                    LineBreakMode="NoWrap"
                                    Text="{Binding Price, StringFormat='€{0:F2}'}"
                                    TextColor="Black" />
                                    <FlexLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.ProductTappedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                    </FlexLayout.GestureRecognizers>
                                </FlexLayout>
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ScrollView>

        <!--  Loading Indicator  -->
        <ActivityIndicator
        Grid.RowSpan="2"
        HorizontalOptions="Center"
        IsRunning="{Binding IsBusy}"
        IsVisible="{Binding IsBusy}"
        VerticalOptions="Center" />

    </Grid>
</ContentPage>